{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-6",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "ask",
      "git commit *": "deny",
      "git push *": "deny",
      "grep *": "allow"
    },
    "read": "allow",
    "list": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "grep": "allow"
  }
}
